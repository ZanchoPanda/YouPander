<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="YouPander.Views.BrowserPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:Localization="clr-namespace:YouPander.Services">

    <Shell.TitleView>
        <Grid HorizontalOptions="Fill">
            <Label
                FontAttributes="Bold"
                FontSize="18"
                HorizontalOptions="Center"
                HorizontalTextAlignment="Center"
                Text="{Binding Source={x:Static Localization:LocalizationResourceManager.Instance}, Path=[Player]}"
                VerticalOptions="Center" />
        </Grid>
    </Shell.TitleView>

    <Grid RowDefinitions="Auto,*">

        <Grid
            Grid.Row="0"
            Padding="8"
            ColumnDefinitions="Auto,*"
            ColumnSpacing="8">

            <Button
                Grid.Column="0"
                Clicked="OnReloadClicked"
                HeightRequest="40"
                Text="🔄"
                WidthRequest="40" />

            <Label
                x:Name="LblUrl"
                Grid.Column="1"
                FontSize="12"
                HorizontalOptions="Fill"
                LineBreakMode="TailTruncation"
                TextColor="Gray"
                VerticalOptions="Center" />

        </Grid>

        <WebView
            x:Name="WebViewControl"
            Grid.Row="1"
            Navigated="OnNavigated"
            Navigating="OnNavigating" />

    </Grid>
</ContentPage>